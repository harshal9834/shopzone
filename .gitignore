# .gitignore - Files to NOT push to GitHub
# ==========================================

# Secret environment variables (NEVER share!)
.env

# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
ENV/

# Django database (we use MongoDB, but just in case)
db.sqlite3

# Static files (generated by collectstatic)
staticfiles/

# Media uploads
media/

# IDE files
.vscode/
.idea/
*.swp

# OS files
.DS_Store
Thumbs.db
